{
  "rule_id": "TRUFFLE-NET-001",
  "name": "Outbound Network Access",
  "severity": "medium",
  "languages": ["python", "javascript", "go", "cpp"],
  "match_type": "regex",
  "patterns": [
    "requests\\.(get|post|put|delete)\\s*\\(",
    "urllib\\.request\\.urlopen",
    "socket\\.connect\\s*\\(",
    "fetch\\s*\\(\\s*['\"]https?://",
    "XMLHttpRequest\\s*\\(",
    "net\\.Dial\\s*\\("
  ],
  "description": "代码发起外部网络请求，可能存在数据泄露风险",
  "recommendation": "确认目标地址是安全的，避免将敏感数据发送到未知服务器",
  "category": "Network Access"
}

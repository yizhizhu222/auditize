{
  "rule_id": "TRUFFLE-SECRET-001",
  "name": "Hardcoded Secrets Detection",
  "severity": "high",
  "languages": ["python", "javascript", "go", "cpp"],
  "match_type": "regex",
  "patterns": [
    "(?i)(?:api[_-]?key|apikey)\\s*[:=]\\s*['\"][^'\"]+['\"]",
    "(?i)(?:password|passwd|pwd)\\s*[:=]\\s*['\"][^'\"]+['\"]",
    "(?i)(?:secret|token)\\s*[:=]\\s*['\"][^'\"]{8,}['\"]",
    "-----BEGIN\\s+(?:RSA\\s+|EC\\s+)?PRIVATE\\s+KEY-----"
  ],
  "description": "代码中检测到硬编码的密钥/密码",
  "recommendation": "将敏感信息移至环境变量或密钥管理服务",
  "category": "Secret Leak"
}
